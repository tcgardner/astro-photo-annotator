{
  "name": "astro-photo-annotator",
  "version": "1.0.0",
  "description": "Web-based astrophoto annotation editor",
  "type": "module",
  "workspaces": ["ui"],
  "engines": { "node": ">=24" },
  "scripts": {
    "start": "tsx src/main.ts",
    "dev:api": "tsx watch src/main.ts",
    "dev:ui": "npm run dev --workspace=ui",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:ui\"",
    "build": "tsc --noEmit && npm run build --workspace=ui",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "better-sqlite3": "^12.10.0",
    "concurrently": "^9.2.1",
    "dotenv": "^16.4.0",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "sharp": "^0.33.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0"
  },
  "devDependencies": {
    "@types/multer": "^1.4.12"
  }
}
